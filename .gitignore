# Python
__pycache__/
*.py[cod]
*.so
.Python
env/
venv/
.env

# Jupyter
.ipynb_checkpoints/
*.ipynb_checkpoints

# Large files (don't commit these - upload separately to Colab)
*.pkl
*.bin
*.pt
*.pth
*.safetensors

# Data files
*.json
# Allow SolidWorks-verified context databases
!sw_parts_db.json
!sw_assemblies_db.json
!sw_mating_context.json
!sw_structure.json
!sw_components_all.json
!sw_mate_specs.json
!sw_inspector_requirements.json

# OS files
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/

# Test / notebook checkpoints
tests/notebooks/.ipynb_checkpoints/

# Pipeline output
debug/
qc_output/

# Model exports
*.onnx

# Local SolidWorks data
sw_json_library/

# Dataset configs (allow callouts.yaml placeholder)
datasets/*.yaml
!datasets/callouts.yaml

# FEA worker artifacts (Stage 4 hand-off package)
# The sweeping *.json ignore above would otherwise silently skip the worker's
# results.json, manifest.json, and part-data JSON -- without these allow rules
# only the .glb would survive, breaking the audit trail. The temp staging
# directory used by scripts/run_fea_extract.ps1 is the one path that must NOT
# be committed: it is transient and only contains residue from interrupted runs.
!incoming_fea/**/*.json
incoming_fea/.staging/
